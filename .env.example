# Template per .env. Copia in .env e compila con i valori reali.
# Il file .env e' ignorato da Git (vedi .gitignore).

# JWT CardTrader. Genera/recupera dal pannello CardTrader: account settings -> API.
# Formato: stringa lunga che inizia per "eyJ...". Validita' tipica diversi mesi.
CT_AUTH_TOKEN=eyJ_metti_qui_il_tuo_token_CardTrader
